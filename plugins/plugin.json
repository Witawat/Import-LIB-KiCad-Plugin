{
  "$schema": "https://go.kicad.org/api/schemas/v1",
  "identifier": "com.github.Witawat.impartGUI",
  "name": "impart GUI for KiCad",
  "description": "Import library files from Octopart, Samacsys, Ultralibrarian, Snapeda and EasyEDA",
  "runtime": {
    "type": "python",
    "version": "3"
  },
  "actions": [
    {
      "identifier": "impart_action-action",
      "name": "impartGUI (IPC API)",
      "description": "impart_action",
      "show-button": true,
      "scopes": [
        "schematic",
        "pcb"
      ],
      "entrypoint": "impart_action.py",
      "icons-light": [
        "icon.png"
      ],
      "icons-dark": [
        "icon.png"
      ]
    },
    {
      "identifier": "impart_launch-exe",
      "name": "impartGUI (Standalone EXE)",
      "description": "Launch the standalone impartGUI.exe",
      "show-button": true,
      "scopes": [
        "schematic",
        "pcb"
      ],
      "entrypoint": "launch_exe.py",
      "icons-light": [
        "icon.png"
      ],
      "icons-dark": [
        "icon.png"
      ]
    }
  ]
}